# Copy to .env and fill in. .env is gitignored; this file is the committed template.

# Runtime environment: development | test | staging | production
NODE_ENV=development

# --- Server ---
# API port (default 4743 if unset)
PORT=

# --- Database (better-sqlite3) ---
# Dev/staging: path to the SQLite file
DEV_DATABASE=
# Production: SQLite file path
DATABASE_URL=

# --- CORS ---
# Allowed browser origin for credentialed requests. If unset, falls back to
# http://localhost:${CLIENT_DEV_PORT} (default port 5173).
CLIENT_ORIGIN=
CLIENT_DEV_PORT=

# --- Auth ---
# REQUIRED: secret used to sign/verify JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime (any `ms` string, e.g. 7d, 12h). Cookie max-age is derived from this.
JWT_EXPIRES_IN=
# Force the HTTPS-only cookie flag. Leave unset to default on in production, off elsewhere.
# COOKIE_SECURE=true
